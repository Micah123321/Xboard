# Docker Compose images and ports
XBOARD_IMAGE=ghcr.io/micah123321/xboard:new
XBOARD_ADMIN_IMAGE=ghcr.io/micah123321/xboard-admin-frontend:new
REDIS_IMAGE=redis:8-alpine
WEB_PORT=7001
USER_PORT=7003
ADMIN_PORT=7002
WS_PORT=8076

# Frontend reverse proxy targets. The default host-gateway target avoids stale
# Docker service DNS in long-running frontend containers after web is recreated.
XBOARD_USER_BACKEND_UPSTREAM=http://host.docker.internal:7001
XBOARD_ADMIN_BACKEND_UPSTREAM=http://host.docker.internal:7001
# Compatibility value used by older templates; new split frontend services use
# XBOARD_USER_BACKEND_UPSTREAM and XBOARD_ADMIN_BACKEND_UPSTREAM.
XBOARD_BACKEND_UPSTREAM=http://host.docker.internal:7001
XBOARD_UPLOAD_UPSTREAM=https://pic.535888.xyz

# Laravel application
APP_NAME=XBoard
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.example
LOG_CHANNEL=stack

# Database: this template expects an external MySQL server
DB_CONNECTION=mysql
DB_HOST=your-mysql-host
DB_PORT=3306
DB_DATABASE=xboard
DB_USERNAME=xboard
DB_PASSWORD=change-me

# Redis: shared unix socket from the redis-data volume
REDIS_HOST=/data/redis.sock
REDIS_PASSWORD=null
REDIS_PORT=0

# Queue, cache and session
BROADCAST_DRIVER=log
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
QUEUE_RETRY_AFTER=90
SESSION_DRIVER=file
MASS_EMAIL_HOURLY_LIMIT=500

# Mail
MAIL_DRIVER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_TIMEOUT=30
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME=XBoard
MAILGUN_DOMAIN=
MAILGUN_SECRET=

# Backup and installation flags
ENABLE_AUTO_BACKUP_AND_UPDATE=false
GOOGLE_CLOUD_KEY_FILE=config/googleCloudStorageKey.json
GOOGLE_CLOUD_STORAGE_BUCKET=
INSTALLED=false
